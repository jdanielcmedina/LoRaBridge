[Unit]
Description=ChirpStack to TTN Bridge
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 -u /usr/local/bin/chirpstack-ttn-bridge.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
