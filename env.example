# ChirpStack to TTN Bridge Configuration
# Copy this file to .env and adjust values

# TTN Configuration
TTN_SERVER=eu1.cloud.thethings.network
TTN_PORT=1700

# ChirpStack MQTT Broker
CHIRPSTACK_MQTT_HOST=mosquitto
CHIRPSTACK_MQTT_PORT=1883
CHIRPSTACK_MQTT_USER=
CHIRPSTACK_MQTT_PASS=

# MQTT Topic Pattern
# Use your region prefix (eu868, us915, au915, etc.)
MQTT_TOPIC=eu868/gateway/+/event/up

